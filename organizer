#!/usr/bin/env bash

set -euo pipefail
trap 'printf "%s\n" "Error on line $LINENO"' ERR

#this opens file descriptor 3 for writing to logs, normal logs
exec 3>>~/.organizer.log
#this opens file descriptor 4 for writing to logs, error logs
exec 4>>~/.organizer.errors.log

# Only use colors if outputting to terminal
if [[ -t 1 ]]; then
  R_BG='\033[41m'
  Y_BG='\033[43m'
  GREEN='\033[32m'
  BLUE='\033[34m'
  BLACK='\033[30m'
  BOLD='\033[1m'
  DIM='\033[2m'
  WHITE="\033[38m"
  RESET='\033[0m'
else
  R_BG=''
  Y_BG=''
  GREEN=''
  BLUE=''
  BOLD=''
  DIM=''
  WHITE=''
  RESET=''
fi

DIRECTORIES_CREATED=1
FILES_MOVED=1
declare -a TEMP_DIRECTORIES
dir_to_operate_on="./"
# this is used to determine whether the user asked for verbose mode with -v option
verbose_mode=false
# this is used to determine if user specified dry_run option or not
dry_run=false

while getopts :nvd: opt; do
  case "$opt" in
  d)
    #check if it is absolute path and real directory
    if [[ "$OPTARG" == /home/* && -d "$OPTARG" ]]; then
      dir_to_operate_on="$OPTARG"
      #also check if there is a trailing slash at the end or should be added
      if [[ "${dir_to_operate_on: -1:1}" == / ]]; then
        dir_to_operate_on="$OPTARG"
      else
        dir_to_operate_on="$OPTARG"
        dir_to_operate_on+="/"
      fi
      #check if directory specified is relative and append pwd to it if it is
    elif [[ "$OPTARG" != /home/* ]]; then
      if [[ -d $PWD/"$OPTARG" ]]; then
        dir_to_operate_on="$OPTARG"
        if [[ "${dir_to_operate_on: -1:1}" == / ]]; then
          dir_to_operate_on=$PWD/"$OPTARG"
        else
          dir_to_operate_on=$PWD/"$OPTARG"
          dir_to_operate_on+="/"
        fi
      else

        #if it is invalid directory, then throw an error to the stderr
        printf "${BOLD}${BLACK}${R_BG}%s${RESET}\n" "✖invalid directory"
        # this redirects those logs to the error logs file descriptor
        printf "[$(date +%F-%T)] %s\n" "✖invalid directory" >&4
        exit 1
      fi
    else

      #if it is invalid directory, then throw an error to the stderr
      printf "${BOLD}${BLACK}${R_BG}%s${RESET}\n" "✖invalid directory"
      # this redirects those logs to the error logs file descriptor
      printf "[$(date +%F-%T)] %s\n" "✖invalid directory" >&4
      exit 1
    fi
    ;;
  n)
    dry_run=true
    ;;
  v)
    verbose_mode=true
    ;;
  :)
    #this is when the option needs an argument like -d option
    printf "${BOLD}${BLACK}${Y_BG}%s %s${RESET}\n" "argument is needed for option" "-$OPTARG"
    printf "[$(date +%F-%T)] %s %s\n" "argument is needed for option" "-$OPTARG" >&4
    exit 1
    ;;
  *)
    exit 1
    ;;
  esac
done

ensure_dir_and_move() {
  declare -n dir=$1
  declare -n itemTobeMoved=$2
  #this first if is for dry_run mode using -n option
  if [[ "$dry_run" == true ]]; then
    ((FILES_MOVED++))
    if [[ -d "$dir_to_operate_on$dir" ]]; then
      printf "${BLUE}${DIM}[DRY-RUN]${RESET} would move %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir"
    else
      ((DIRECTORIES_CREATED++))
      mkdir "$dir_to_operate_on$dir"
      #this is for stores temporary directories, after dry_run, they will be deletd
      TEMP_DIRECTORIES+=("$dir_to_operate_on$dir")
      printf "${BLUE}${DIM}[DRY-RUN]${RESET} would  create directory %s/\n" "${dir_to_operate_on#./}$dir"
      printf "${BLUE}${DIM}[DRY-RUN]${RESET} would move %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir"
    fi
    return
  fi

  # silent mode without -v or -n
  if [[ $verbose_mode == false ]]; then
    if [[ -d $dir_to_operate_on$dir ]]; then
      ((FILES_MOVED++))
      mv "$itemTobeMoved" "${dir_to_operate_on#./}$dir"
      printf "[$(date +%F-%T)] [✓] moved: %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir" >&3
    else
      ((FILES_MOVED++))
      ((DIRECTORIES_CREATED++))
      mkdir "$dir_to_operate_on$dir"
      mv "$itemTobeMoved" "$dir_to_operate_on$dir"
      printf "[$(date +%F-%T)] [✓] created directory: %s/\n" "${dir_to_operate_on#./}$dir" >&3
      printf "[$(date +%F-%T)] [✓] moved: %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir" >&3
    fi
  else

    # verbose mode
    if [[ -d $dir_to_operate_on$dir ]]; then
      ((FILES_MOVED++))
      mv "$itemTobeMoved" "$dir_to_operate_on$dir"
      printf "${GREEN}[✓]${RESET} ${WHITE}${BOLD}moved:${RESET} %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir"
      printf "[$(date +%F-%T)] [✓] moved: %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir" >&3
    else
      ((FILES_MOVED++))
      ((DIRECTORIES_CREATED++))
      mkdir "$dir_to_operate_on$dir"
      printf "${GREEN}[✓]${RESET} ${WHITE}${BOLD}created directory:${RESET} %s/\n" "${dir_to_operate_on#./}$dir"
      mv "$itemTobeMoved" "$dir_to_operate_on$dir"
      printf "${GREEN}[✓]${RESET} ${WHITE}${BOLD}moved:${RESET} %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir"
      # these don't output to the screen, they instead redirect to logs file
      printf "[$(date +%F-%T)] [✓] created directory: %s/\n" "${dir_to_operate_on#./}$dir" >&3
      printf "[$(date +%F-%T)] [✓] moved: %s -> %s/\n" "${itemTobeMoved#./}" "${dir_to_operate_on#./}$dir" >&3
    fi
  fi
}

organize_files_by_type() {

  for extension in "$dir_to_operate_on"*; do
    if [[ -d $extension ]]; then
      continue
    fi
    case "${extension}" in

    *.pdf | *.doc | *.docx | *.txt | *.rtf | *.odt | *.md)
      local category="Documents"
      ensure_dir_and_move category extension

      ;;
    *.xls | *.xlsx | *.csv | *.ods)
      local category="Spreadsheets"
      ensure_dir_and_move category extension
      ;;
    *.ppt | *.pptx | *.odp)
      local category="Presentations"
      ensure_dir_and_move category extension
      ;;

    *.jpg | *.jpeg | *.png | *.gif | *.bmp | *.svg | *.webp | *.ico | *.tiff | *.tif)
      local category="Images"
      ensure_dir_and_move category extension
      ;;

    *.avi | *.mkv | *.mov | *.wmv | *.flv | *.webm | *.m4v | *.mpg | *.mpeg | *.mp4)
      local category="Videos"
      ensure_dir_and_move category extension
      ;;

    *.mp3 | *.wav | *.flac | *.aac | *.ogg | *.m4a | *.wma | *.opus)
      local category="Audio"
      ensure_dir_and_move category extension
      ;;

    *.zip | *.rar | *.tar | *.gz | *.7z | *.bz2 | *.xz | *.tgz)
      local category="Archives"
      ensure_dir_and_move category extension
      ;;

    *.py | *.java | *.cpp | *.c | *.h | *.js | *.ts | *.html | *.css | *.php | *.rb | *.go | *.rs | *.swift)
      local category="Code"
      ensure_dir_and_move category extension
      ;;

    *.exe | *.app | *.deb | *.rpm | *.apk | *.dmg | *.msi | *.sh)
      local category="Executables"
      ensure_dir_and_move category extension
      ;;

    *)
      local category="Other"
      ensure_dir_and_move category extension
      ;;
    esac
  done
}

organize_files_by_type

# this is a little summary header that will have a long ---- and summary quote and then ----
header() {
  printf "\n%s %b %s\n" \
    "$(printf '─%.0s' {1..25})" \
    "${BOLD}${BLACK}${Y_BG}${1}${RESET}" \
    "$(printf '─%.0s' {1..25})"
}

message_summary() {
  # this will be the summary message when users are actaully moving files either -v or not
  if [[ "$dry_run" == false ]]; then
    printf "\n"
    header "ORGANIZATION COMPLETE"
    printf "\n"
    printf " ${GREEN}${BOLD}$((FILES_MOVED - 1))${RESET} %s\n" "Files moved"
    printf " ${BLUE}${BOLD}$((DIRECTORIES_CREATED - 1))${RESET} %s\n" "Directories created"
    # these redirect to the logs file, not the stdout
    printf " [$(date +%F-%T)] $((FILES_MOVED - 1)) %s\n" "Files moved" >&3
    printf " [$(date +%F-%T)] $((DIRECTORIES_CREATED - 1)) %s\n" "Directories created" >&3
    printf "\n"
  else
    # this will be the summary message when user runs the dry run mode
    printf "\n"
    header "DRY-RUN SUMMARY"
    printf "\n"
    printf " ${GREEN}${BOLD}$((FILES_MOVED - 1))${RESET} %s\n" "file(s) would be moved"
    printf " ${BLUE}${BOLD}$((DIRECTORIES_CREATED - 1))${RESET} %s\n" "directory(ies) would be created"
    printf " %s\n" "To actually perform these operations, run without -n flag:"
    printf " %s\n" "organizer -v -d ${dir_to_operate_on}"
  fi
}
message_summary

# this for loop is for dry-run only, it will delete directories that has been created
#  those directories is stored in TEMP_DIRECTORIES array, since it is dry run only.
# i dont have any solution that is better than this for now since i need to count how
# many directories that would be created if run in normal mode without dry_run
for i in "${TEMP_DIRECTORIES[@]}"; do
  if [[ "$dir_to_operate_on" == ./ ]]; then
    rm --recursive "$i"
  else
    rm --recursive "$i"
  fi
done

exec 3>&-
exec 4>&-
